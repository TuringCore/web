{
  "name": "lorenz-attractor-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A tiny Scala-docs-inspired Lorenz attractor site deployable on Cloudflare Workers.",
  "scripts": {
    "verify:cloudflare": "node ./scripts/verify-cloudflare-assets.mjs",
    "dev": "wrangler dev",
    "precheck": "npm run verify:cloudflare",
    "check": "wrangler deploy --dry-run",
    "predeploy": "npm run verify:cloudflare",
    "deploy": "wrangler deploy"
  },
  "devDependencies": {
    "wrangler": "3.114.17"
  }
}

